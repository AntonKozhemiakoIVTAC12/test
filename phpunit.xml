<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.0/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         executionOrder="depends,defects">
    <testsuites>
        <testsuite name="CRM Stages">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">administrator/components/com_crm/src</directory>
        </include>
        <exclude>
            <directory>administrator/components/com_crm/src/Administrator/View</directory>
        </exclude>
    </source>
</phpunit>
